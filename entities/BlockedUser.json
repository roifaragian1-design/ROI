{
  "name": "BlockedUser",
  "type": "object",
  "properties": {
    "user_email": {
      "type": "string",
      "description": "Email of the user doing the blocking"
    },
    "blocked_email": {
      "type": "string",
      "description": "Email of the blocked user"
    },
    "blocked_name": {
      "type": "string",
      "description": "Name of the blocked user"
    },
    "blocked_at": {
      "type": "string",
