{
  "name": "GameScore",
  "type": "object",
  "properties": {
    "player_email": {
      "type": "string"
    },
    "player_name": {
      "type": "string"
    },
    "game_type": {
      "type": "string",
      "enum": [
        "tic_tac_toe",
        "rock_paper_scissors",
        "catch_ball",
        "trivia",
        "tug_of_war",
        "color_catch",
        "vault_code",
        "reverse_sentence",
        "country_city",
        "power_checkers",
        "kitchen_clash"
      ]
    },
    "score": {
      "type": "number",
      "default": 0
    },
    "wins": {
      "type": "number",
      "default": 0
    },
    "losses": {
      "type": "number",
      "default": 0
    },
    "draws": {
      "type": "number",
      "default": 0
    }
  },
  "required": [
    "player_email",
    "player_name",
    "game_type",
    "score"
  ]
}
