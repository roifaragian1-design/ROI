{
  "name": "GameScore",
  "type": "object",
  "properties": {
    "player_email": {
      "type": "string",
      "format": "email",
      "description": "Email of the player"
    },
    "player_name": {
      "type": "string",
      "description": "Display name of the player"
    },
    "game_type": {
      "type": "string",
      "enum": [
        "tic_tac_toe",
        "rock_paper_scissors",
        "catch_ball",
        "trivia",
        "color_catch",
        "vault_code",
        "reverse_sentence",
        "country_city",
        "kitchen_clash"
      ]
    },
    "score": {
      "type": "integer",
      "default": 0
    },
    "wins": {
      "type": "integer",
      "default": 0
    },
    "losses": {
      "type": "integer",
      "default": 0
    },
    "draws": {
      "type": "integer",
      "default": 0
    },
    "created_at": {
      "type": "string",
      "format": "date-time",
      "description": "Timestamp when the score record was created"
    }
  },
  "required": [
    "player_email",
    "player_name",
    "game_type",
    "score",
    "created_at"
  ]
}
