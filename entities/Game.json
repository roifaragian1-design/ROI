{
  "name": "Game",
  "type": "object",
  "properties": {
    "game_type": {
      "type": "string",
      "enum": [
        "tic_tac_toe",
        "rock_paper_scissors",
        "catch_ball",
        "trivia",
        "color_catch",
        "vault_code",
        "reverse_sentence",
        "country_city",
        "kitchen_clash"
      ]
    },
    "players": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "minItems": 2,
      "maxItems": 4,
      "description": "Array of player emails (2-4 players)"
    },
    "player_names": {
      "type": "object",
      "description": "Map of email -> display name"
    },
    "current_turn": {
      "type": "string",
      "description": "Email of player whose turn it is"
    },
    "game_state": {
      "type": "object",
      "description": "Current state of the game"
    },
    "status": {
      "type": "string",
      "enum": [
        "waiting",
        "active",
        "finished"
      ],
      "default": "waiting"
    },
    "winner": {
      "type": "string",
      "description": "Email of the winning player, or 'draw' if the game ended in a draw"
    },
    "conversation_id": {
      "type": "string",
      "description": "ID of the conversation this game belongs to"
    },
    "group_id": {
      "type": "string",
      "description": "ID of the group this game belongs to (if started from a group)"
    },
    "created_at": {
      "type": "string",
      "format": "date-time",
      "description": "Timestamp when the game was created"
    },
    "started_at": {
      "type": "string",
      "format": "date-time",
      "description": "Timestamp when the game started"
    },
    "updated_at": {
      "type": "string",
      "format": "date-time",
      "description": "Last time the game state was updated"
    },
    "finished_at": {
      "type": "string",
      "format": "date-time",
      "description": "Timestamp when the game ended"
    }
  },
  "required": [
    "game_type",
    "players",
    "status",
    "created_at"
  ]
}
